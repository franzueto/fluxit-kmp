<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto-backup exclusions for API ≤ 30 (ADR-009b, plan/06 §10).

  v1 is local-only with no sync (ADR-003): restoring lists/photos onto a new
  device from a cloud backup — with no server to reconcile against — would be
  confusing, and `platform-photo`'s storage explicitly assumes files/photos/ is
  not backed up. So we exclude the SQLDelight database (incl. its WAL/shm
  sidecars, since write-ahead logging is enabled in DriverFactory) and the photo
  store. Everything else is allowed (there is no other user data today).

  v2 reversal: once sync ships, drop these excludes so an iCloud/Drive restore
  brings lists back. The iOS side is already backed up (default), per §10.
-->
<full-backup-content>
    <exclude domain="database" path="fluxit.db" />
    <exclude domain="database" path="fluxit.db-wal" />
    <exclude domain="database" path="fluxit.db-shm" />
    <exclude domain="file" path="photos/" />
</full-backup-content>
