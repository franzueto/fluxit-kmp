<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      ADR-009b (plan/06 §10): auto-backup is enabled, but the SQLDelight database
      and the photo store are excluded via the rules below (v1 is local-only, no
      sync — a cloud/device restore of lists+photos with no server to reconcile
      would confuse, and platform-photo assumes files/photos/ is not backed up).
      fullBackupContent covers API ≤ 30; dataExtractionRules covers API 31+.
    -->
    <application
        android:name=".FluxItApp"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.FluxIt">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FluxIt">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
