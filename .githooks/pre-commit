#!/usr/bin/env bash
# FluxIt pre-commit hook — Phase 01 §8.5.
#
# Auto-formats staged Kotlin / KTS / Markdown files via Spotless + ktlint
# before each commit. Re-stages the formatted versions so the committed tree
# matches what the gates expect.
#
# Install once per clone:    scripts/install-hooks.sh
# Uninstall:                  git config --unset core.hooksPath
# Bypass for a single commit: git commit --no-verify  (use sparingly)

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_files() {
    git diff --cached --name-only --diff-filter=ACMR -- "$@"
}

kotlin_staged="$(staged_files '*.kt' '*.kts' || true)"
markdown_staged="$(staged_files '*.md' || true)"

if [[ -z "$kotlin_staged" && -z "$markdown_staged" ]]; then
    exit 0
fi

gradle_tasks=()
if [[ -n "$kotlin_staged" ]]; then
    gradle_tasks+=("ktlintFormat")
fi
if [[ -n "$kotlin_staged" || -n "$markdown_staged" ]]; then
    gradle_tasks+=("spotlessApply")
fi

echo "[pre-commit] Running: ./gradlew ${gradle_tasks[*]}"
./gradlew --quiet "${gradle_tasks[@]}"

# Re-stage only the files that were already staged, so unrelated working-tree
# changes don't leak into the commit.
while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    [[ -f "$f" ]] || continue
    git add -- "$f"
done <<<"$kotlin_staged"$'\n'"$markdown_staged"
