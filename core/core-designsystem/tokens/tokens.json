{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "FluxIt design tokens — single source of truth for Compose + SwiftUI. See plan/02_DESIGN_SYSTEM.md §1 and ADR-005. Edit this file, then run `./gradlew :core:core-designsystem:generateTokens` (or it runs automatically on Compose compile / iOS build).",

  "font": {
    "family": {
      "inter": {
        "$type": "fontFamily",
        "$value": ["Inter", "system-ui", "sans-serif"]
      }
    }
  },

  "shape": {
    "$type": "dimension",
    "sm":      { "$value": "4px" },
    "default": { "$value": "8px" },
    "md":      { "$value": "12px" },
    "lg":      { "$value": "16px" },
    "xl":      { "$value": "24px" },
    "full":    { "$value": "9999px" }
  },

  "spacing": {
    "$type": "dimension",
    "scale": {
      "xs":  { "$value": "4px" },
      "sm":  { "$value": "8px" },
      "md":  { "$value": "12px" },
      "lg":  { "$value": "16px" },
      "xl":  { "$value": "24px" },
      "2xl": { "$value": "32px" },
      "3xl": { "$value": "48px" }
    },
    "containerPadding": { "$value": "16px" },
    "stackGap":         { "$value": "8px" },
    "itemPaddingX":     { "$value": "16px" },
    "itemPaddingY":     { "$value": "12px" },
    "fabOffset":        { "$value": "32px" }
  },

  "light": {
    "$description": "Reserved for a future light theme. Empty in v1 (dark-mode-only — see anticipated ADR-005b)."
  },

  "dark": {
    "color": {
      "$type": "color",
      "background": {
        "dark": { "$value": "#101822ff", "$description": "App background." }
      },
      "surface": {
        "card":      { "$value": "#1e2632ff", "$description": "Default card / list-item surface." },
        "search":    { "$value": "#1e2632ff", "$description": "Search field fill (same hue as cards by design)." },
        "cardMuted": { "$value": "#1e263280", "$description": "Resting list-item state — surface.card @ 50% alpha." }
      },
      "text": {
        "primary": { "$value": "#ffffffff" },
        "muted":   { "$value": "#9da8b9ff" }
      },
      "primary": {
        "blue":       { "$value": "#2b7ceeff", "$description": "Primary CTA, FAB, active-tab tint." },
        "blueShadow": { "$value": "#2b7cee66", "$description": "FAB shadow tint — primary.blue @ 40% alpha." }
      },
      "divider": {
        "subtle": { "$value": "#9da8b91f", "$description": "Hairline divider — text.muted @ 12% alpha." }
      },
      "accent": {
        "rose":    { "$value": "#f43f5eff", "$description": "Destructive action tint — outlined buttons, swipe-to-delete. Also a list-identity swatch (ColorToken.ACCENT_ROSE)." },
        "emerald": { "$value": "#10b981ff", "$description": "List-identity swatch (ColorToken.ACCENT_EMERALD)." },
        "orange":  { "$value": "#f97316ff", "$description": "List-identity swatch (ColorToken.ACCENT_ORANGE)." },
        "indigo":  { "$value": "#6366f1ff", "$description": "List-identity swatch (ColorToken.ACCENT_INDIGO)." },
        "sky":     { "$value": "#0ea5e9ff", "$description": "List-identity swatch (ColorToken.ACCENT_SKY)." }
      }
    },

    "typography": {
      "$type": "typography",
      "displayLg": {
        "$value": {
          "fontFamily":     "{font.family.inter}",
          "fontWeight":     700,
          "fontSize":       "32px",
          "lineHeight":     1.2,
          "letterSpacing": "-0.02em"
        }
      },
      "titleMd": {
        "$value": {
          "fontFamily": "{font.family.inter}",
          "fontWeight": 600,
          "fontSize":   "18px",
          "lineHeight": 1.4
        }
      },
      "bodyMd": {
        "$value": {
          "fontFamily": "{font.family.inter}",
          "fontWeight": 400,
          "fontSize":   "16px",
          "lineHeight": 1.5
        }
      },
      "labelSm": {
        "$value": {
          "fontFamily": "{font.family.inter}",
          "fontWeight": 400,
          "fontSize":   "14px",
          "lineHeight": 1.4
        }
      },
      "captionXs": {
        "$value": {
          "fontFamily": "{font.family.inter}",
          "fontWeight": 500,
          "fontSize":   "10px",
          "lineHeight": 1.0
        }
      }
    },

    "elevation": {
      "$type": "shadow",
      "$description": "Levels 0 and 1 are tonal-only (no shadow). level2.fab and blur.backdrop will be added when Phase 02 §7 (backdrop blur) and the FAB primitive land.",
      "level0": {
        "$value": { "color": "#00000000", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "0px" },
        "$description": "App background — no shadow."
      },
      "level1": {
        "$value": { "color": "#00000000", "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "0px" },
        "$description": "Surface (cards) — tonal lift only, no cast shadow."
      }
    }
  }
}
